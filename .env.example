# Server Configuration
# The port the backend server will run on (default: 5001 to avoid conflict with frontend)
PORT=5001

# The execution environment (development, production, or test)
NODE_ENV=development

# Database Configuration
# The hostname or IP address of your MySQL server
DB_HOST=localhost

# The username used to connect to the database
DB_USER=root

# The password for the database user (leave empty if none)
DB_PASSWORD=

# The name of the database to be used (will be created automatically if it doesn't exist)
DB_NAME=the_wine_corner

# Authentication
# A long, random string used to sign JWT tokens for security
JWT_TOKEN_KEY=your_secure_random_secret_key_here

# How long the JWT token remains valid (e.g., 24h, 7d, 3600s)
JWT_TOKEN_EXPIRED=24h

# Logging
# The format used by the Morgan logging middleware (dev, combined, common, short, tiny)
MORGAN_ENVIRONMENT=dev
